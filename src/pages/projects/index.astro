---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ds/ProjectCard.astro';
import SectionHeader from '../../components/ds/SectionHeader.astro';
import projectsData from '../../data/projects.json';

const projects = projectsData.sort((a, b) => a.displayOrder - b.displayOrder);
const categories = [...new Set(projects.map((p) => p.category))];
const totalCount = projects.length;
---

<BaseLayout
  title="Projects"
  description="CloudOps, Kubernetes, and Platform Engineering projects by Elvis Rafael Gross — real-world work with architecture, operational value, and runbooks."
>
  <section style="padding:var(--section-gap) clamp(20px,4vw,48px)">
    <div style="max-width:var(--max-width);margin:0 auto">
      <SectionHeader
        label="PROJECTS"
        en={{ heading: 'Projects', sub: `Production-grade work in AWS CloudOps, Kubernetes, hybrid infrastructure, and observability. ${totalCount} project${totalCount !== 1 ? 's' : ''}.` }}
        es={{ heading: 'Proyectos', sub: `Trabajo de producción en AWS CloudOps, Kubernetes, infraestructura híbrida y observabilidad. ${totalCount} proyecto${totalCount !== 1 ? 's' : ''}.` }}
      />

      <div class="ds-stagger" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:16px">
        {projects.map((p) => (
          <ProjectCard
            href={`/projects/${p.slug}`}
            title={p.title}
            description={p.shortDescription}
            status={p.status}
            tags={p.tags ?? p.awsServices ?? []}
            featured={p.featured}
          />
        ))}
      </div>

      {projects.length === 0 && (
        <div style="padding:80px 20px;text-align:center;border:1px dashed var(--border);border-radius:4px">
          <p style="font-size:var(--text-sm);color:var(--text-faint)">No projects yet — check back soon.</p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
