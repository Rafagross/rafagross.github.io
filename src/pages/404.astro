---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Page Not Found" noIndex={true}>
  <section class="py-24 md:py-32">
    <div class="container text-center" style="max-width:500px">
      <p class="font-mono text-6xl font-bold mb-6" style="color:var(--color-accent)">404</p>
      <h1 class="text-2xl font-semibold mb-4" style="color:var(--color-text-primary)">Page not found</h1>
      <p class="text-base mb-8" style="color:var(--color-text-secondary)">
        This route doesn't exist. The resource may have moved or the URL may be incorrect.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/" class="px-4 py-2 rounded-md text-sm font-medium hover:opacity-80"
          style="background:var(--color-accent); color:white">← Home</a>
        <a href="/projects" class="px-4 py-2 rounded-md text-sm font-medium hover:opacity-80"
          style="background:var(--color-surface); color:var(--color-text-primary); border:1px solid var(--color-border)">Projects</a>
        <a href="/runbooks" class="px-4 py-2 rounded-md text-sm font-medium hover:opacity-80"
          style="background:var(--color-surface); color:var(--color-text-primary); border:1px solid var(--color-border)">Runbooks</a>
      </div>
    </div>
  </section>
</BaseLayout>
