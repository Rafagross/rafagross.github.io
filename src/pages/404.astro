---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/ds/Button.astro';
---

<BaseLayout title="404 — Page Not Found" noIndex={true}>
  <section style="padding:var(--section-gap) clamp(20px,4vw,48px);display:flex;align-items:center;justify-content:center;min-height:60vh">
    <div style="max-width:500px;margin:0 auto;text-align:center">
      <p style="font-family:var(--font-mono);font-size:4rem;font-weight:700;color:var(--text-faint);margin-bottom:24px;letter-spacing:var(--tracking-display)">404</p>
      <h1 style="font-family:var(--font-display);font-size:var(--text-h2);font-weight:700;letter-spacing:var(--tracking-tight);color:var(--text);margin-bottom:16px">Page not found</h1>
      <p style="font-family:var(--font-sans);font-size:var(--text-base);color:var(--text-muted);line-height:var(--leading-relaxed);margin-bottom:32px">
        This route doesn't exist. The resource may have moved or the URL may be incorrect.
      </p>
      <div style="display:flex;flex-wrap:wrap;justify-content:center;gap:10px">
        <Button href="/" variant="primary">← Home</Button>
        <Button href="/projects" variant="secondary">Projects</Button>
        <Button href="/runbooks" variant="secondary">Runbooks</Button>
      </div>
    </div>
  </section>
</BaseLayout>
