---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import WritingRow from '../../../components/ds/WritingRow.astro';
import SectionHeader from '../../../components/ds/SectionHeader.astro';
import { getCollection } from 'astro:content';
import { WRITING_CATEGORIES, categoryToSlug, slugToCategory, formatDate } from '../../../lib/filters';
import { formatReadingTime, estimateReadingTime } from '../../../lib/reading-time';

export async function getStaticPaths() {
  const posts = await getCollection('writing', ({ data }) => !data.draft);
  return WRITING_CATEGORIES.map((category) => {
    const slug = categoryToSlug(category);
    const categoryPosts = posts
      .filter((p) => p.data.category === category)
      .sort((a, b) => b.data.publishedDate.getTime() - a.data.publishedDate.getTime());
    return {
      params: { category: slug },
      props: { category, posts: categoryPosts },
    };
  });
}

const { category, posts } = Astro.props;
---

<BaseLayout
  title={`${category} — Writing`}
  description={`Technical writing, notes, and tutorials about ${category} by Rafael Gross.`}
>
  <section style="padding:var(--section-gap) clamp(20px,4vw,48px)">
    <div style="max-width:var(--max-width);margin:0 auto">
      <nav style="margin-bottom:32px;font-size:var(--text-sm)" aria-label="Breadcrumb">
        <ol style="display:flex;align-items:center;gap:8px;color:var(--text-muted)">
          <li><a href="/writing" style="color:var(--text-muted);text-decoration:underline;text-underline-offset:2px">Writing</a></li>
          <li aria-hidden="true" style="color:var(--text-faint)">/</li>
          <li aria-current="page" style="color:var(--text)">{category}</li>
        </ol>
      </nav>

      <SectionHeader
        label="CATEGORY"
        en={{ heading: category, sub: `${posts.length} article${posts.length !== 1 ? 's' : ''}` }}
        es={{ heading: category, sub: `${posts.length} artículo${posts.length !== 1 ? 's' : ''}` }}
      />

      {posts.length > 0 ? (
        <div style="display:flex;flex-direction:column;gap:1px">
          {posts.map((post) => (
            <WritingRow
              href={`/writing/${post.id}`}
              title={post.data.title}
              category={post.data.category}
              date={post.data.publishedDate.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}
              description={post.data.description}
            />
          ))}
        </div>
      ) : (
        <div style="padding:80px 20px;text-align:center;border:1px dashed var(--border);border-radius:4px">
          <p style="font-size:var(--text-sm);color:var(--text-faint)">No posts in this category yet.</p>
          <a href="/writing" style="font-size:var(--text-sm);color:var(--text-muted);display:inline-block;margin-top:12px;text-decoration:underline;text-underline-offset:2px">← Back to all writing</a>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
