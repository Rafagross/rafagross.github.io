---
import BaseLayout from '../../layouts/BaseLayout.astro';
import WritingRow from '../../components/ds/WritingRow.astro';
import SectionHeader from '../../components/ds/SectionHeader.astro';
import { getCollection } from 'astro:content';
import { WRITING_CATEGORIES, categoryToSlug, formatDate } from '../../lib/filters';
import { estimateReadingTime, formatReadingTime } from '../../lib/reading-time';

const allPosts = await getCollection('writing', ({ data }) => !data.draft);
const posts = allPosts.sort(
  (a, b) => b.data.publishedDate.getTime() - a.data.publishedDate.getTime()
);

const categories = WRITING_CATEGORIES.filter((cat) =>
  posts.some((p) => p.data.category === cat)
);
---

<BaseLayout
  title="Writing"
  description="CloudOps notes, Kubernetes labs, Linux troubleshooting, homelab docs, and architecture decisions by Rafael Gross."
>
  <section style="padding:var(--section-gap) clamp(20px,4vw,48px)">
    <div style="max-width:var(--max-width);margin:0 auto">
      <SectionHeader
        label="WRITING"
        en={{ heading: 'Writing', sub: 'Technical notes, tutorials, homelab documentation, and architecture decisions.' }}
        es={{ heading: 'Escritura', sub: 'Notas técnicas, tutoriales, documentación de homelab y decisiones de arquitectura.' }}
      />

      {posts.length > 0 ? (
        <div style="display:flex;flex-direction:column;gap:1px">
          {posts.map((post) => (
            <WritingRow
              href={`/writing/${post.id}`}
              title={post.data.title}
              category={post.data.category}
              date={post.data.publishedDate.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}
              description={post.data.description}
            />
          ))}
        </div>
      ) : (
        <div style="padding:80px 20px;text-align:center;border:1px dashed var(--border);border-radius:4px">
          <p style="font-size:var(--text-base);font-weight:500;color:var(--text);margin-bottom:8px">Writing coming soon</p>
          <p style="font-size:var(--text-sm);color:var(--text-faint)">Technical notes and tutorials are in progress.</p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
