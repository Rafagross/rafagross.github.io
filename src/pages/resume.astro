---
import BaseLayout from '../layouts/BaseLayout.astro';
import skillsData from '../data/skills.json';
import certsData from '../data/certifications.json';
---

<BaseLayout
  title="Resume"
  description="Elvis Rafael Gross — CloudOps Engineer resume. AWS, Kubernetes, Platform Engineering, SRE."
>
  <section class="py-12 md:py-16">
    <div class="container" style="max-width:800px">
      <!-- Actions bar -->
      <div class="flex items-center justify-between mb-10 pb-6" style="border-bottom:1px solid var(--color-border)">
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest mb-1" style="color:var(--color-accent)">Resume</p>
          <p class="text-sm" style="color:var(--color-text-muted)">Last updated: May 2026</p>
        </div>
        <div class="flex gap-3">
          <a
            href="/cover-letter.pdf"
            download
            class="inline-flex items-center gap-2 px-4 py-2 rounded-md text-sm font-medium hover:opacity-80 transition-opacity"
            style="background:var(--color-surface); color:var(--color-text-primary); border:1px solid var(--color-border)"
          >
            Cover Letter
          </a>
          <a
            href="/resume.pdf"
            download
            class="inline-flex items-center gap-2 px-4 py-2 rounded-md text-sm font-medium hover:opacity-80 transition-opacity"
            style="background:var(--color-accent); color:white"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            Download PDF
          </a>
        </div>
      </div>

      <div id="resume-content" class="space-y-10">

        <!-- Header -->
        <header>
          <h1 class="text-3xl font-semibold mb-1" style="color:var(--color-text-primary); letter-spacing:-0.02em">
            Elvis Rafael Gross Cardero
          </h1>
          <p class="text-lg mb-3" style="color:var(--color-text-secondary)">
            CloudOps Engineer · Platform Engineer · SRE
          </p>
          <div class="flex flex-wrap gap-4 text-sm" style="color:var(--color-text-muted)">
            <span>Las Vegas, NV</span>
            <a href="mailto:rafagross15@gmail.com" class="hover:underline" style="color:var(--color-accent)">rafagross15@gmail.com</a>
            <a href="https://www.linkedin.com/in/erafael-gross" target="_blank" rel="noopener noreferrer" class="hover:underline" style="color:var(--color-accent)">linkedin.com/in/erafael-gross</a>
            <a href="https://www.credly.com/users/rafa-gross" target="_blank" rel="noopener noreferrer" class="hover:underline" style="color:var(--color-accent)">credly.com/users/rafa-gross</a>
          </div>
        </header>

        <!-- Summary -->
        <section>
          <h2 class="text-xs font-semibold uppercase tracking-widest mb-4 pb-2" style="color:var(--color-text-muted); border-bottom:1px solid var(--color-border)">
            Summary
          </h2>
          <p class="text-sm leading-relaxed" style="color:var(--color-text-secondary)">
            Cloud Operations Engineer with production experience in AWS and GCP, focused on infrastructure reliability,
            automation, and observability at enterprise scale. Delivered EKS operations, SSM-based patch management,
            and disaster recovery strategies across multi-account AWS environments supporting mission-critical workloads.
            Holds five active cloud and security certifications — AWS CloudOps, GCP PCA, GCP ACE, CompTIA Cloud+, and ISC2 CC —
            with CKA in progress. Nevada Gaming License holder.
          </p>
        </section>

        <!-- Experience -->
        <section>
          <h2 class="text-xs font-semibold uppercase tracking-widest mb-6 pb-2" style="color:var(--color-text-muted); border-bottom:1px solid var(--color-border)">
            Experience
          </h2>
          <div class="space-y-8">

            <!-- IGT -->
            <div>
              <div class="flex flex-wrap items-start justify-between gap-2 mb-3">
                <div>
                  <h3 class="text-sm font-semibold" style="color:var(--color-text-primary)">Cloud Operations Engineer</h3>
                  <p class="text-sm" style="color:var(--color-text-secondary)">International Game Technology (IGT) · Las Vegas, NV</p>
                </div>
                <span class="text-xs font-mono flex-shrink-0" style="color:var(--color-text-muted)">Mar 2025 – Apr 2026</span>
              </div>
              <ul class="space-y-2">
                <li class="flex items-start gap-2 text-sm" style="color:var(--color-text-secondary)">
                  <span class="mt-1 flex-shrink-0" style="color:var(--color-accent)">→</span>
                  <span>Managed multi-account AWS environments supporting mission-critical gaming infrastructure across production workloads serving millions of end users.</span>
                </li>
                <li class="flex items-start gap-2 text-sm" style="color:var(--color-text-secondary)">
                  <span class="mt-1 flex-shrink-0" style="color:var(--color-accent)">→</span>
                  <span>Led EKS cluster version upgrades in production using a Golden AMI strategy — zero-downtime node rotations via controlled drain/cordon workflows.</span>
                </li>
                <li class="flex items-start gap-2 text-sm" style="color:var(--color-text-secondary)">
                  <span class="mt-1 flex-shrink-0" style="color:var(--color-accent)">→</span>
                  <span>Designed SSM Patch Manager workflows across 200+ Linux and Windows EC2 instances, enforcing compliance and reducing manual intervention.</span>
                </li>
                <li class="flex items-start gap-2 text-sm" style="color:var(--color-text-secondary)">
                  <span class="mt-1 flex-shrink-0" style="color:var(--color-accent)">→</span>
                  <span>Implemented CloudWatch alarms, custom metrics, and log-based alerting — reduced mean time to detection (MTTD) for production incidents.</span>
                </li>
                <li class="flex items-start gap-2 text-sm" style="color:var(--color-text-secondary)">
                  <span class="mt-1 flex-shrink-0" style="color:var(--color-accent)">→</span>
                  <span>Owned DR strategy aligned to defined RTO/RPO targets, including DR testing cycles and runbook documentation ensuring repeatable recovery procedures.</span>
                </li>
              </ul>
            </div>

            <!-- CODESA -->
            <div>
              <div class="flex flex-wrap items-start justify-between gap-2 mb-3">
                <div>
                  <h3 class="text-sm font-semibold" style="color:var(--color-text-primary)">Pre-Sales Cloud Engineer</h3>
                  <p class="text-sm" style="color:var(--color-text-secondary)">CODESA (Google Cloud Partner) · Lima, Peru</p>
                </div>
                <span class="text-xs font-mono flex-shrink-0" style="color:var(--color-text-muted)">Apr 2021 – Nov 2024</span>
              </div>
              <ul class="space-y-2">
                <li class="flex items-start gap-2 text-sm" style="color:var(--color-text-secondary)">
                  <span class="mt-1 flex-shrink-0" style="color:var(--color-accent)">→</span>
                  <span>Architected production-ready GCP solutions for enterprise clients using Cloud Run, Pub/Sub, BigQuery, Cloud Functions, and IAM.</span>
                </li>
                <li class="flex items-start gap-2 text-sm" style="color:var(--color-text-secondary)">
                  <span class="mt-1 flex-shrink-0" style="color:var(--color-accent)">→</span>
                  <span>Built end-to-end PoCs for serverless and real-time data pipeline architectures, accelerating client cloud adoption and reducing technical evaluation cycles.</span>
                </li>
                <li class="flex items-start gap-2 text-sm" style="color:var(--color-text-secondary)">
                  <span class="mt-1 flex-shrink-0" style="color:var(--color-accent)">→</span>
                  <span>Delivered live technical workshops and architecture demos to executive stakeholders, translating complex GCP capabilities into clear business value.</span>
                </li>
              </ul>
            </div>
          </div>
        </section>

        <!-- Technical Skills -->
        <section>
          <h2 class="text-xs font-semibold uppercase tracking-widest mb-4 pb-2" style="color:var(--color-text-muted); border-bottom:1px solid var(--color-border)">
            Technical Skills
          </h2>
          <div class="space-y-3">
            {skillsData.categories.map((cat) => (
              <div class="flex gap-4 text-sm">
                <span class="flex-shrink-0 w-40 font-medium" style="color:var(--color-text-primary)">{cat.name}</span>
                <span style="color:var(--color-text-secondary)">
                  {cat.skills.map((s) => s.name).join(' · ')}
                </span>
              </div>
            ))}
          </div>
        </section>

        <!-- Certifications -->
        <section>
          <h2 class="text-xs font-semibold uppercase tracking-widest mb-4 pb-2" style="color:var(--color-text-muted); border-bottom:1px solid var(--color-border)">
            Certifications
          </h2>
          <div class="space-y-2">
            {certsData.certifications.map((cert) => (
              <div class="flex items-center justify-between text-sm">
                <div class="flex items-center gap-2">
                  <span style="color:var(--color-text-primary)">{cert.name}</span>
                  <span class={`text-xs px-2 py-0.5 rounded ${
                    cert.status === 'active'
                      ? 'text-green-700 bg-green-100 dark:text-green-400 dark:bg-green-900/30'
                      : cert.status === 'target'
                      ? 'text-blue-700 bg-blue-100 dark:text-blue-400 dark:bg-blue-900/30'
                      : 'text-gray-500 bg-gray-100 dark:bg-gray-800'
                  }`}>
                    {cert.status === 'target' ? 'In Progress' : cert.status}
                  </span>
                </div>
                {cert.credentialUrl && (
                  <a href={cert.credentialUrl} target="_blank" rel="noopener noreferrer"
                    class="text-xs hover:underline" style="color:var(--color-accent)">
                    Verify ↗
                  </a>
                )}
              </div>
            ))}
          </div>
        </section>

        <!-- Projects -->
        <section>
          <h2 class="text-xs font-semibold uppercase tracking-widest mb-4 pb-2" style="color:var(--color-text-muted); border-bottom:1px solid var(--color-border)">
            Selected Projects
          </h2>
          <p class="text-sm mb-3" style="color:var(--color-text-secondary)">
            Full project details including architecture diagrams, operational value, and linked runbooks:
          </p>
          <a href="/projects" class="text-sm hover:underline" style="color:var(--color-accent)">rafagross.github.io/projects →</a>
        </section>

      </div>
    </div>
  </section>
</BaseLayout>
