---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RunbookCard from '../../components/ds/RunbookCard.astro';
import SectionHeader from '../../components/ds/SectionHeader.astro';
import { getCollection } from 'astro:content';
import { WRITING_CATEGORIES } from '../../lib/filters';

const allRunbooks = await getCollection('runbooks', ({ data }) => !data.draft);
const runbooks = allRunbooks.sort(
  (a, b) => b.data.publishedDate.getTime() - a.data.publishedDate.getTime()
);

const categories = [...new Set(runbooks.map((r) => r.data.category))];
const severities = ['P1', 'P2', 'P3', 'P4'];
---

<BaseLayout
  title="Runbooks"
  description="AWS CloudOps, Kubernetes, and Linux troubleshooting runbooks by Rafael Gross — structured operational procedures for real incidents."
>
  <section style="padding:var(--section-gap) clamp(20px,4vw,48px)">
    <div style="max-width:var(--max-width);margin:0 auto">
      <SectionHeader
        label="RUNBOOKS"
        en={{ heading: 'Runbooks', sub: 'Step-by-step operational procedures for troubleshooting, remediation, and routine operations.' }}
        es={{ heading: 'Runbooks', sub: 'Procedimientos operativos paso a paso para resolución de problemas, remediación y operaciones rutinarias.' }}
      />

      {runbooks.length > 0 ? (
        <div class="ds-stagger" style="display:flex;flex-direction:column;gap:12px">
          {runbooks.map((rb) => (
            <RunbookCard
              href={`/runbooks/${rb.id}`}
              title={rb.data.title}
              severity={rb.data.severity}
              status={rb.data.status}
              estimatedTime={rb.data.estimatedTime}
              tags={rb.data.tags}
            />
          ))}
        </div>
      ) : (
        <div style="padding:80px 20px;text-align:center;border:1px dashed var(--border);border-radius:4px">
          <p style="font-size:var(--text-base);font-weight:500;color:var(--text);margin-bottom:8px">Runbooks coming soon</p>
          <p style="font-size:var(--text-sm);color:var(--text-faint)">Operational runbooks are being authored and will be published shortly.</p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
