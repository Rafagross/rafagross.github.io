---
import BaseLayout from '../layouts/BaseLayout.astro';
import skillsData from '../data/skills.json';
import certsData from '../data/certifications.json';
---

<BaseLayout
  title="About"
  description="Elvis Rafael Gross — CloudOps Engineer, Platform Engineer, SRE. AWS, Kubernetes, hybrid infrastructure, and operational excellence."
>
  <section class="py-12 md:py-16">
    <div class="container" style="max-width:800px">

      <!-- Header -->
      <header class="mb-12 pb-10 reveal" style="border-bottom:1px solid var(--color-border)">
        <p class="text-xs font-semibold uppercase tracking-widest mb-2 font-mono" style="color:var(--color-text-muted)">About</p>
        <h1 class="text-3xl md:text-4xl font-semibold mb-4" style="color:var(--color-text-primary); letter-spacing:-0.02em">
          Elvis Rafael Gross
        </h1>
        <p class="text-lg font-medium mb-6" style="color:var(--color-text-secondary)">
          CloudOps Engineer · Platform Engineer · SRE
        </p>
        <div class="space-y-4 text-base leading-relaxed" style="color:var(--color-text-secondary)">
          <p>
            I work at the intersection of cloud infrastructure and operational reliability —
            managing AWS EC2 fleets, operating EKS clusters in production, and building the
            observability that makes incidents diagnosable before they become outages.
          </p>
          <p>
            My approach is production-first: runbooks written before incidents, least privilege
            from day one, and alarms that are actionable rather than just present.
            This portfolio reflects that — real projects, real operational decisions, honest
            documentation of what worked and what didn't.
          </p>
          <p>
            Currently focused on AWS CloudOps, Kubernetes platform engineering on EKS and k3s,
            SSM-based fleet management, and CKA preparation.
          </p>
        </div>
      </header>

      <!-- Skills -->
      <section class="mb-12 reveal">
        <h2 class="text-sm font-semibold uppercase tracking-widest mb-6 font-mono" style="color:var(--color-text-muted)">Technical Skills</h2>
        <div class="space-y-8">
          {skillsData.categories.map((cat) => (
            <div>
              <h3 class="text-xs font-semibold uppercase tracking-wide mb-3 font-mono" style="color:var(--color-text-muted)">{cat.name}</h3>
              <div class="space-y-1">
                {cat.skills.map((skill) => (
                  <div class="flex items-start gap-3 py-2.5" style="border-bottom:1px solid var(--color-border)">
                    <div class="flex-1">
                      <div class="flex items-center gap-2 mb-0.5">
                        <span class="text-sm font-medium" style="color:var(--color-text-primary)">{skill.name}</span>
                        <span
                          class="text-xs px-1.5 py-0.5 rounded font-mono font-medium"
                          style={skill.level === 'advanced'
                            ? 'background:#16a34a1a; color:#16a34a; border:1px solid #16a34a33'
                            : 'background:#d974061a; color:#d97406; border:1px solid #d9740633'
                          }
                        >
                          {skill.level}
                        </span>
                      </div>
                      <p class="text-xs leading-relaxed" style="color:var(--color-text-muted)">{skill.note}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Certifications -->
      <section class="mb-12 reveal">
        <h2 class="text-sm font-semibold uppercase tracking-widest mb-6 font-mono" style="color:var(--color-text-muted)">Certifications</h2>
        <div class="space-y-2.5">
          {certsData.certifications.map((cert) => (
            <div
              class="flex items-center gap-4 p-4 rounded-lg card-interactive"
              style="background:var(--color-surface); border:1px solid var(--color-border)"
            >
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-0.5 flex-wrap">
                  <span class="text-sm font-medium" style="color:var(--color-text-primary)">{cert.name}</span>
                  <span
                    class="text-xs px-1.5 py-0.5 rounded font-mono font-medium flex-shrink-0"
                    style={cert.status === 'active'
                      ? 'background:#16a34a1a; color:#16a34a; border:1px solid #16a34a33'
                      : cert.status === 'target'
                      ? 'background:#2563eb1a; color:#2563eb; border:1px solid #2563eb33'
                      : 'background:var(--color-surface-raised); color:var(--color-text-muted); border:1px solid var(--color-border)'
                    }
                  >
                    {cert.status === 'target' ? 'In Progress' : cert.status}
                  </span>
                </div>
                <p class="text-xs font-mono" style="color:var(--color-text-muted)">
                  {cert.issuer} · {cert.abbrev}
                </p>
              </div>
              {cert.credentialUrl && (
                <a
                  href={cert.credentialUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-xs font-mono hover:opacity-60 transition-opacity flex-shrink-0"
                  style="color:var(--color-text-muted)"
                >
                  Verify ↗
                </a>
              )}
            </div>
          ))}
        </div>
      </section>

      <!-- Links -->
      <section class="reveal">
        <h2 class="text-sm font-semibold uppercase tracking-widest mb-6 font-mono" style="color:var(--color-text-muted)">Links</h2>
        <div class="flex flex-wrap gap-3">
          <a
            href="https://github.com/Rafagross"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-4 py-2.5 rounded-md text-sm font-medium hover:opacity-70 transition-opacity"
            style="background:var(--color-surface); color:var(--color-text-primary); border:1px solid var(--color-border)"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
            </svg>
            GitHub
          </a>
          <a
            href="https://linkedin.com/in/erafael-gross"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-4 py-2.5 rounded-md text-sm font-medium hover:opacity-70 transition-opacity"
            style="background:var(--color-surface); color:var(--color-text-primary); border:1px solid var(--color-border)"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
            </svg>
            LinkedIn
          </a>
          <a
            href="https://www.credly.com/users/rafa-gross"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-4 py-2.5 rounded-md text-sm font-medium hover:opacity-70 transition-opacity"
            style="background:var(--color-surface); color:var(--color-text-primary); border:1px solid var(--color-border)"
          >
            Credly ↗
          </a>
          <a
            href="/resume"
            class="inline-flex items-center gap-2 px-4 py-2.5 rounded-md text-sm font-medium hover:opacity-70 transition-opacity"
            style="background:var(--color-text-primary); color:var(--color-bg)"
          >
            View Resume
          </a>
        </div>
      </section>

    </div>
  </section>
</BaseLayout>
