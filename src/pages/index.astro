---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/islands/Hero.jsx';
import Terminal from '../components/islands/Terminal.jsx';
import ProjectCard from '../components/ds/ProjectCard.astro';
import RunbookCard from '../components/ds/RunbookCard.astro';
import WritingRow from '../components/ds/WritingRow.astro';
import SectionHeader from '../components/ds/SectionHeader.astro';
import { getCollection } from 'astro:content';
import projectsData from '../data/projects.json';

const runbooks = await getCollection('runbooks', ({ data }) => !data.draft);
const writing = await getCollection('writing', ({ data }) => !data.draft);

const recentRunbooks = runbooks
  .sort((a, b) => b.data.publishedDate.getTime() - a.data.publishedDate.getTime())
  .slice(0, 3);

const recentWriting = writing
  .sort((a, b) => b.data.publishedDate.getTime() - a.data.publishedDate.getTime())
  .slice(0, 3);

const featuredProjects = projectsData
  .filter((p) => p.featured)
  .sort((a, b) => a.displayOrder - b.displayOrder);
---

<BaseLayout title="Home">
  <Hero client:load />

  <!-- Projects -->
  <section id="projects" style="padding:var(--section-gap) clamp(20px,4vw,48px);background:var(--bg)">
    <div style="max-width:var(--max-width);margin:0 auto">
      <SectionHeader label="01"
        en={{ heading: 'Projects', sub: 'Selected infrastructure work' }}
        es={{ heading: 'Proyectos', sub: 'Trabajo de infraestructura seleccionado' }} />
      <div class="ds-stagger" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:16px">
        {featuredProjects.map((p) => (
          <ProjectCard
            href={`/projects/${p.slug}`}
            title={p.title}
            description={p.shortDescription}
            status={p.status}
            tags={p.tags ?? p.awsServices ?? []}
            featured={p.featured}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Terminal (decorative) -->
  <Terminal client:visible />

  <!-- Runbooks -->
  <section id="runbooks" style="padding:var(--section-gap) clamp(20px,4vw,48px);background:var(--bg-subtle);border-top:1px solid var(--border);border-bottom:1px solid var(--border)">
    <div style="max-width:var(--max-width);margin:0 auto">
      <SectionHeader label="02"
        en={{ heading: 'Runbooks', sub: 'Field-tested operational procedures' }}
        es={{ heading: 'Runbooks', sub: 'Procedimientos operativos probados en campo' }} />
      <div class="ds-stagger" style="display:flex;flex-direction:column;gap:12px">
        {recentRunbooks.map((rb) => (
          <RunbookCard
            href={`/runbooks/${rb.id}`}
            title={rb.data.title}
            severity={rb.data.severity}
            status={rb.data.status}
            estimatedTime={rb.data.estimatedTime}
            tags={rb.data.tags}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Writing -->
  <section id="writing" style="padding:var(--section-gap) clamp(20px,4vw,48px);background:var(--bg)">
    <div style="max-width:var(--max-width);margin:0 auto">
      <SectionHeader label="03"
        en={{ heading: 'Writing', sub: 'Technical notes and field observations' }}
        es={{ heading: 'Escritura', sub: 'Notas técnicas y observaciones de campo' }} />
      <div style="display:flex;flex-direction:column;gap:1px">
        {recentWriting.map((post) => (
          <WritingRow
            href={`/writing/${post.id}`}
            title={post.data.title}
            category={post.data.category}
            date={post.data.publishedDate.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}
            description={post.data.description}
          />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
