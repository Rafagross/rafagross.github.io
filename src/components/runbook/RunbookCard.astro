---
import Tag from '../ui/Tag.astro';
import { getSeverityClasses, getStatusClasses, formatDate } from '../../lib/filters';

interface Props {
  slug: string;
  title: string;
  description: string;
  category: string;
  severity: string;
  estimatedTime: string;
  status: string;
  tags: string[];
  awsServices: string[];
  updatedDate?: Date;
  publishedDate: Date;
}

const {
  slug,
  title,
  description,
  category,
  severity,
  estimatedTime,
  status,
  tags,
  awsServices,
  updatedDate,
  publishedDate,
} = Astro.props;

const severityClasses = getSeverityClasses(severity);
const statusClasses = getStatusClasses(status);
const displayDate = formatDate(updatedDate ?? publishedDate);
---

<article
  class="group relative flex flex-col rounded-lg overflow-hidden transition-shadow hover:shadow-lg"
  style="background:var(--color-surface); border:1px solid var(--color-border)"
>
  <div class="flex flex-col flex-1 p-5">
    <!-- Top row -->
    <div class="flex items-start justify-between gap-3 mb-3">
      <div class="flex flex-wrap items-center gap-2">
        <span class={`inline-flex items-center px-2.5 py-1 rounded text-xs font-semibold font-mono ${severityClasses}`}>
          {severity}
        </span>
        <span class="text-xs" style="color:var(--color-text-muted)">{category}</span>
      </div>
      <span class={`flex-shrink-0 inline-flex items-center px-2 py-0.5 rounded text-xs font-medium ${statusClasses}`}>
        {status}
      </span>
    </div>

    <!-- Title -->
    <h3 class="text-base font-semibold mb-2 leading-snug group-hover:opacity-80 transition-opacity" style="color:var(--color-text-primary)">
      <a href={`/runbooks/${slug}`} class="stretched-link">{title}</a>
    </h3>

    <!-- Description -->
    <p class="text-sm leading-relaxed mb-4 flex-1" style="color:var(--color-text-secondary)">
      {description}
    </p>

    <!-- Services -->
    {awsServices.length > 0 && (
      <div class="flex flex-wrap gap-1.5 mb-3">
        {awsServices.slice(0, 4).map((svc) => (
          <Tag size="sm" variant="accent">{svc}</Tag>
        ))}
      </div>
    )}

    <!-- Tags -->
    <div class="flex flex-wrap gap-1.5 mb-4">
      {tags.slice(0, 4).map((tag) => <Tag size="sm">{tag}</Tag>)}
    </div>

    <!-- Footer -->
    <div class="flex items-center justify-between pt-3 mt-auto text-xs" style="border-top:1px solid var(--color-border); color:var(--color-text-muted)">
      <span class="flex items-center gap-1">
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        {estimatedTime}
      </span>
      <span>{displayDate}</span>
    </div>
  </div>
</article>

<style>
  .stretched-link::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
  }
</style>
