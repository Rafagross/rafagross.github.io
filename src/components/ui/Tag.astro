---
interface Props {
  size?: 'sm' | 'md';
  variant?: 'default' | 'accent' | 'muted';
}

const { size = 'md', variant = 'default' } = Astro.props;

const sizeClasses = {
  sm: 'px-2 py-0.5 text-xs',
  md: 'px-2.5 py-0.5 text-xs',
};

const variantStyles = {
  default: 'background:var(--color-surface-raised); color:var(--color-text-secondary); border:1px solid var(--color-border)',
  accent: 'background:var(--color-accent-muted); color:var(--color-accent); border:1px solid transparent',
  muted: 'background:var(--color-surface-raised); color:var(--color-text-muted); border:1px solid var(--color-border)',
};
---

<span
  class={`inline-flex items-center rounded font-mono font-medium leading-none ${sizeClasses[size]}`}
  style={variantStyles[variant]}
>
  <slot />
</span>
