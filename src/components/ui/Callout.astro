---
interface Props {
  type?: 'info' | 'warning' | 'danger' | 'tip' | 'note';
  title?: string;
}

const { type = 'info', title } = Astro.props;

const config = {
  info: {
    icon: 'ℹ',
    style: 'background:var(--color-accent-muted); border-color:var(--color-accent)',
    titleColor: 'color:var(--color-accent)',
    label: title ?? 'Note',
  },
  warning: {
    icon: '⚠',
    style: 'background:#fef3c7; border-color:#d97706',
    titleColor: 'color:#92400e',
    label: title ?? 'Warning',
  },
  danger: {
    icon: '✖',
    style: 'background:#fee2e2; border-color:#dc2626',
    titleColor: 'color:#991b1b',
    label: title ?? 'Danger',
  },
  tip: {
    icon: '💡',
    style: 'background:#d1fae5; border-color:#16a34a',
    titleColor: 'color:#14532d',
    label: title ?? 'Tip',
  },
  note: {
    icon: '📝',
    style: 'background:var(--color-surface-raised); border-color:var(--color-border-strong)',
    titleColor: 'color:var(--color-text-secondary)',
    label: title ?? 'Note',
  },
};

const c = config[type];
---

<div class="my-5 p-4 rounded-lg" style={`${c.style}; border-left:3px solid`}>
  <p class="text-sm font-semibold mb-1" style={c.titleColor}>
    <span aria-hidden="true">{c.icon} </span>{c.label}
  </p>
  <div class="text-sm" style="color:var(--color-text-secondary)">
    <slot />
  </div>
</div>
