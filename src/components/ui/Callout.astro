---
interface Props {
  type?: 'info' | 'warning' | 'danger' | 'tip' | 'note';
  title?: string;
}

const { type = 'info', title } = Astro.props;

/*
 * Monochrome DS design:
 *   info    — hairline border, "NOTE" label
 *   warning — thick left border (2px), "WARNING" label
 *   danger  — thick left border (2px), "DANGER" label
 *   tip     — thin border + --green accent dot, "TIP" label (--green is the one allowed hue)
 *   note    — same as info, alias
 *
 * All backgrounds use --bg-subtle.
 * Labels are uppercase mono in --text-muted, except tip which uses --green.
 */

const config = {
  info: {
    borderLeft: '1px solid var(--border-strong)',
    label: title ?? 'NOTE',
    labelColor: 'var(--text-muted)',
  },
  warning: {
    borderLeft: '2px solid var(--border-strong)',
    label: title ?? 'WARNING',
    labelColor: 'var(--text)',
  },
  danger: {
    borderLeft: '2px solid var(--text-muted)',
    label: title ?? 'DANGER',
    labelColor: 'var(--text)',
  },
  tip: {
    borderLeft: '2px solid var(--green)',
    label: title ?? 'TIP',
    labelColor: 'var(--green)',
  },
  note: {
    borderLeft: '1px solid var(--border-strong)',
    label: title ?? 'NOTE',
    labelColor: 'var(--text-muted)',
  },
};

const c = config[type];
---

<div
  class="callout"
  style={`border-left:${c.borderLeft}`}
>
  <p class="callout-label" style={`color:${c.labelColor}`}>
    {c.label}
  </p>
  <div class="callout-body">
    <slot />
  </div>
</div>

<style>
.callout {
  margin: 1.25rem 0;
  padding: 0.875rem 1rem;
  background: var(--bg-subtle);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  font-family: var(--font-sans);
}

.callout-label {
  font-size: 0.6875rem;  /* --text-2xs */
  font-family: var(--font-mono);
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  margin: 0 0 0.375rem 0;
}

.callout-body {
  font-size: var(--text-sm);
  color: var(--text-muted);
  line-height: 1.6;
}

/* reset prose margins inside callout body */
.callout-body > :first-child { margin-top: 0; }
.callout-body > :last-child  { margin-bottom: 0; }
</style>
