---
import Tag from '../ui/Tag.astro';
import { getStatusClasses } from '../../lib/filters';

interface Props {
  slug: string;
  title: string;
  shortDescription: string;
  category: string;
  status: string;
  tags: string[];
  techStack: Record<string, string[]>;
  awsServices: string[];
  featured?: boolean;
  stars?: number | null;
  primaryLanguage?: string | null;
  githubUrl: string;
}

const {
  slug,
  title,
  shortDescription,
  category,
  status,
  tags,
  techStack,
  awsServices,
  featured = false,
  stars,
  primaryLanguage,
  githubUrl,
} = Astro.props;

const statusClasses = getStatusClasses(status);
const topTags = tags.slice(0, 5);
// Flatten tech stack for display
const allTech = Object.values(techStack).flat().slice(0, 6);
---

<article
  class={`group relative flex flex-col h-full rounded-lg overflow-hidden transition-shadow hover:shadow-lg ${featured ? 'ring-1' : ''}`}
  style={`background:var(--color-surface); border:1px solid var(--color-border); ${featured ? 'ring-color:var(--color-accent-muted)' : ''}`}
>
  <!-- Top bar: category + status -->
  <div class="flex items-center justify-between px-5 pt-5 pb-3">
    <span class="text-xs font-medium" style="color:var(--color-text-muted)">{category}</span>
    <div class="flex items-center gap-2">
      {featured && (
        <span class="text-xs px-2 py-0.5 rounded font-medium" style="background:var(--color-accent); color:white">Featured</span>
      )}
      <span class={`inline-flex items-center px-2 py-0.5 rounded text-xs font-medium ${statusClasses}`}>
        {status}
      </span>
    </div>
  </div>

  <!-- Content -->
  <div class="flex flex-col flex-1 px-5 pb-5">
    <h3 class="text-base font-semibold mb-2 leading-snug group-hover:opacity-80 transition-opacity" style="color:var(--color-text-primary)">
      <a href={`/projects/${slug}`} class="stretched-link">
        {title}
      </a>
    </h3>

    <p class="text-sm leading-relaxed mb-4 flex-1" style="color:var(--color-text-secondary)">
      {shortDescription}
    </p>

    <!-- Tech badges -->
    {awsServices.length > 0 && (
      <div class="flex flex-wrap gap-1.5 mb-3">
        {awsServices.slice(0, 4).map((svc) => (
          <Tag size="sm" variant="accent">{svc}</Tag>
        ))}
        {awsServices.length > 4 && (
          <span class="text-xs" style="color:var(--color-text-muted)">+{awsServices.length - 4}</span>
        )}
      </div>
    )}

    <div class="flex flex-wrap gap-1.5 mb-4">
      {topTags.map((tag) => <Tag size="sm">{tag}</Tag>)}
    </div>

    <!-- Footer row -->
    <div class="flex items-center justify-between mt-auto pt-3" style="border-top:1px solid var(--color-border)">
      {primaryLanguage ? (
        <span class="text-xs font-mono" style="color:var(--color-text-muted)">{primaryLanguage}</span>
      ) : <span />}

      <div class="flex items-center gap-3">
        {stars != null && (
          <span class="flex items-center gap-1 text-xs" style="color:var(--color-text-muted)">
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
            </svg>
            {stars}
          </span>
        )}
        <a
          href={githubUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="text-xs hover:opacity-70 transition-opacity"
          style="color:var(--color-text-muted)"
          aria-label={`View ${title} on GitHub`}
          onclick="event.stopPropagation()"
        >
          GitHub ↗
        </a>
      </div>
    </div>
  </div>
</article>

<style>
  .stretched-link::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
  }
  a[onclick] {
    position: relative;
    z-index: 2;
  }
</style>
