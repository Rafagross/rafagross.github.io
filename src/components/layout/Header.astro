---
const navLinks = [
  { href: '/projects', label: 'Projects' },
  { href: '/runbooks', label: 'Runbooks' },
  { href: '/writing', label: 'Writing' },
  { href: '/about', label: 'About' },
  { href: '/resume', label: 'Resume' },
  { href: '/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname;
---

<header
  class="sticky top-0 z-50 backdrop-blur-md"
  style="background:var(--color-nav-bg); border-bottom:1px solid var(--color-border)"
  transition:persist
>
  <div class="container">
    <div class="flex items-center justify-between h-16">
      <!-- Wordmark with monogram badge -->
      <a href="/" class="flex items-center gap-3 font-semibold text-base hover:opacity-80 transition-opacity" style="color:var(--color-text-primary)">
        <span
          class="font-mono text-xs font-semibold px-2 py-1 rounded inline-flex items-center justify-center"
          style="background:var(--color-text-primary); color:var(--color-bg); min-width:28px"
          aria-hidden="true"
        >
          RG
        </span>
        <span class="hidden sm:inline">Rafael Gross</span>
        <span class="hidden md:inline text-sm font-mono font-normal" style="color:var(--color-text-muted)">/ CloudOps</span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-1" aria-label="Main navigation">
        {navLinks.map(({ href, label }) => {
          const isActive = href === '/'
            ? currentPath === '/'
            : currentPath.startsWith(href);
          return (
            <a
              href={href}
              class={`px-3 py-1.5 rounded text-sm font-medium transition-colors ${
                isActive ? 'font-semibold' : 'hover:opacity-80'
              }`}
              style={isActive
                ? 'background:var(--color-surface-raised); color:var(--color-text-primary)'
                : 'color:var(--color-text-secondary)'}
              aria-current={isActive ? 'page' : undefined}
            >
              {label}
            </a>
          );
        })}
      </nav>

      <!-- Actions -->
      <div class="flex items-center gap-2">
        <button
          id="theme-toggle"
          class="p-2 rounded-md transition-colors hover:opacity-70"
          style="color:var(--color-text-secondary); background:transparent"
          aria-label="Toggle dark mode"
          title="Toggle light/dark mode"
        >
          <svg class="hidden dark:block w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
          </svg>
          <svg class="block dark:hidden w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
          </svg>
        </button>

        <button
          id="mobile-menu-btn"
          class="md:hidden p-2 rounded-md transition-colors hover:opacity-70"
          style="color:var(--color-text-secondary)"
          aria-label="Open navigation menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg id="menu-icon" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="close-icon" class="hidden w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <div
    id="mobile-menu"
    class="hidden md:hidden"
    style="border-top:1px solid var(--color-border); background:var(--color-nav-bg)"
  >
    <nav class="container py-3 flex flex-col gap-1" aria-label="Mobile navigation">
      {navLinks.map(({ href, label }) => {
        const isActive = href === '/'
          ? currentPath === '/'
          : currentPath.startsWith(href);
        return (
          <a
            href={href}
            class={`px-3 py-2 rounded text-sm font-medium transition-colors ${isActive ? 'font-semibold' : ''}`}
            style={isActive
              ? 'background:var(--color-surface-raised); color:var(--color-text-primary)'
              : 'color:var(--color-text-secondary)'}
            aria-current={isActive ? 'page' : undefined}
          >
            {label}
          </a>
        );
      })}
    </nav>
  </div>
</header>

<script>
  function setupHeader() {
    const btn = document.getElementById('theme-toggle');
    btn?.addEventListener('click', () => {
      const isDark = document.documentElement.classList.toggle('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
    });

    const mobileBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const menuIcon = document.getElementById('menu-icon');
    const closeIcon = document.getElementById('close-icon');

    mobileBtn?.addEventListener('click', () => {
      mobileMenu?.classList.toggle('hidden');
      const isOpen = !mobileMenu?.classList.contains('hidden');
      mobileBtn.setAttribute('aria-expanded', String(isOpen));
      menuIcon?.classList.toggle('hidden', isOpen);
      closeIcon?.classList.toggle('hidden', !isOpen);
    });
  }

  setupHeader();
  document.addEventListener('astro:page-load', setupHeader);
</script>
