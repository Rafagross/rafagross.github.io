---
const year = new Date().getFullYear();
---

<footer class="mt-auto pt-16 pb-10" style="border-top:1px solid var(--color-border); background:var(--color-bg-subtle)">
  <div class="container">

    <!-- CTA row -->
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6 mb-10 pb-10" style="border-bottom:1px solid var(--color-border)">
      <div>
        <p class="text-xs font-mono uppercase tracking-widest mb-2" style="color:var(--color-text-muted)">Available for new roles</p>
        <h2 class="text-xl md:text-2xl font-semibold" style="color:var(--color-text-primary); letter-spacing:-0.02em">
          Building CloudOps platforms that don't break at 2am.
        </h2>
      </div>
      <div class="flex gap-3 flex-shrink-0">
        <a
          href="/contact"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-md text-sm font-medium transition-opacity hover:opacity-80"
          style="background:var(--color-text-primary); color:var(--color-bg)"
        >
          Get in touch →
        </a>
        <a
          href="/resume"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-md text-sm font-medium transition-opacity hover:opacity-70"
          style="background:transparent; color:var(--color-text-primary); border:1px solid var(--color-border)"
        >
          Resume
        </a>
      </div>
    </div>

    <!-- Bottom row -->
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      <div class="flex items-center gap-3">
        <span
          class="font-mono text-xs font-semibold px-2 py-1 rounded"
          style="background:var(--color-text-primary); color:var(--color-bg)"
        >
          RG
        </span>
        <div>
          <p class="text-sm font-medium" style="color:var(--color-text-primary)">Elvis Rafael Gross</p>
          <p class="text-xs font-mono" style="color:var(--color-text-muted)">CloudOps · Platform Engineering · SRE</p>
        </div>
      </div>

      <nav class="flex flex-wrap justify-center gap-4 text-sm" aria-label="Footer navigation">
        <a href="/projects" class="hover:opacity-60 transition-opacity" style="color:var(--color-text-muted)">Projects</a>
        <a href="/runbooks" class="hover:opacity-60 transition-opacity" style="color:var(--color-text-muted)">Runbooks</a>
        <a href="/writing" class="hover:opacity-60 transition-opacity" style="color:var(--color-text-muted)">Writing</a>
        <a href="/rss.xml" class="hover:opacity-60 transition-opacity" style="color:var(--color-text-muted)">RSS</a>
      </nav>

      <div class="flex items-center gap-3">
        <a
          href="https://github.com/Rafagross"
          target="_blank"
          rel="noopener noreferrer"
          class="p-2 rounded-md hover:opacity-60 transition-opacity"
          style="color:var(--color-text-muted)"
          aria-label="GitHub"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
          </svg>
        </a>
        <a
          href="https://linkedin.com/in/erafael-gross"
          target="_blank"
          rel="noopener noreferrer"
          class="p-2 rounded-md hover:opacity-60 transition-opacity"
          style="color:var(--color-text-muted)"
          aria-label="LinkedIn"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
          </svg>
        </a>
        <a
          href="https://credly.com/users/rafa-gross"
          target="_blank"
          rel="noopener noreferrer"
          class="px-2 py-2 rounded-md hover:opacity-60 transition-opacity text-xs font-mono"
          style="color:var(--color-text-muted)"
          aria-label="Credly"
        >
          Credly
        </a>
      </div>
    </div>

    <p class="text-xs font-mono text-center sm:text-left mt-8" style="color:var(--color-text-muted)">
      © {year} Elvis Rafael Gross · Built with Astro · Hosted on GitHub Pages
    </p>
  </div>
</footer>
