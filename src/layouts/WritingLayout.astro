---
import BaseLayout from './BaseLayout.astro';
import Tag from '../components/ui/Tag.astro';
import { formatDate, categoryToSlug } from '../lib/filters';
import { estimateReadingTime, formatReadingTime } from '../lib/reading-time';

interface Props {
  title: string;
  description: string;
  category: string;
  tags: string[];
  publishedDate: Date;
  updatedDate?: Date;
  readingTime?: number;
  rawContent?: string;
}

const {
  title,
  description,
  category,
  tags,
  publishedDate,
  updatedDate,
  readingTime,
  rawContent = '',
} = Astro.props;

const catSlug = categoryToSlug(category);
const published = formatDate(publishedDate);
const updated = updatedDate ? formatDate(updatedDate) : null;
const readTime = readingTime ?? estimateReadingTime(rawContent);
const readTimeStr = formatReadingTime(readTime);
---

<BaseLayout title={title} description={description}>
  <article class="py-12 md:py-16">
    <div class="container" style="max-width:800px">
      <!-- Breadcrumb -->
      <nav class="mb-8 text-sm" aria-label="Breadcrumb">
        <ol class="flex items-center gap-2" style="color:var(--color-text-muted)">
          <li><a href="/writing" class="hover:underline" style="color:var(--color-accent)">Writing</a></li>
          <li aria-hidden="true">/</li>
          <li>
            <a href={`/writing/category/${catSlug}`} class="hover:underline" style="color:var(--color-accent)">
              {category}
            </a>
          </li>
          <li aria-hidden="true">/</li>
          <li aria-current="page" style="color:var(--color-text-secondary)">{title}</li>
        </ol>
      </nav>

      <!-- Header -->
      <header class="mb-10 pb-8" style="border-bottom:1px solid var(--color-border)">
        <div class="mb-3">
          <a href={`/writing/category/${catSlug}`}
            class="inline-flex items-center px-2.5 py-0.5 rounded text-xs font-medium hover:opacity-80"
            style="background:var(--color-accent-muted); color:var(--color-accent)">
            {category}
          </a>
        </div>

        <h1 class="text-2xl md:text-3xl font-semibold mb-4 leading-tight" style="color:var(--color-text-primary); letter-spacing:-0.015em">
          {title}
        </h1>

        <p class="text-base leading-relaxed mb-5" style="color:var(--color-text-secondary)">{description}</p>

        <div class="flex flex-wrap items-center gap-4 text-sm" style="color:var(--color-text-muted)">
          <span>{published}</span>
          {updated && updated !== published && <span>· Updated {updated}</span>}
          <span>· {readTimeStr}</span>
        </div>
      </header>

      <!-- Article Content -->
      <div class="prose max-w-none">
        <slot />
      </div>

      <!-- Footer tags -->
      <footer class="mt-12 pt-8" style="border-top:1px solid var(--color-border)">
        <div class="flex flex-wrap gap-2">
          {tags.map((tag) => <Tag>{tag}</Tag>)}
        </div>
        <div class="mt-6">
          <a href="/writing" style="color:var(--color-accent)" class="text-sm hover:underline">← Back to Writing</a>
        </div>
      </footer>
    </div>
  </article>
</BaseLayout>
