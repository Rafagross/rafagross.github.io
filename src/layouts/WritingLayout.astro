---
import BaseLayout from './BaseLayout.astro';
import Tag from '../components/ds/Tag.astro';
import { formatDate, categoryToSlug } from '../lib/filters';
import { estimateReadingTime, formatReadingTime } from '../lib/reading-time';

interface Props {
  title: string;
  description: string;
  category: string;
  tags: string[];
  publishedDate: Date;
  updatedDate?: Date;
  readingTime?: number;
  rawContent?: string;
}

const {
  title,
  description,
  category,
  tags,
  publishedDate,
  updatedDate,
  readingTime,
  rawContent = '',
} = Astro.props;

const catSlug = categoryToSlug(category);
const published = formatDate(publishedDate);
const updated = updatedDate ? formatDate(updatedDate) : null;
const readTime = readingTime ?? estimateReadingTime(rawContent);
const readTimeStr = formatReadingTime(readTime);
---

<BaseLayout title={title} description={description}>
  <article style="padding:3rem 0 4rem">
    <div style="width:100%;max-width:var(--max-width);margin-left:auto;margin-right:auto;padding-left:1.5rem;padding-right:1.5rem">
      <!-- Breadcrumb -->
      <nav class="mb-8" aria-label="Breadcrumb">
        <ol class="flex items-center gap-2" style="font-family:var(--font-mono);font-size:var(--text-xs);color:var(--text-faint)">
          <li><a href="/writing" class="ds-link" style="color:var(--text-muted)">Writing</a></li>
          <li aria-hidden="true">/</li>
          <li>
            <a href={`/writing/category/${catSlug}`} class="ds-link" style="color:var(--text-muted)">
              {category}
            </a>
          </li>
          <li aria-hidden="true">/</li>
          <li aria-current="page" style="color:var(--text-faint)">{title}</li>
        </ol>
      </nav>

      <!-- Header -->
      <header class="mb-10 pb-8" style="border-bottom:1px solid var(--border);max-width:var(--max-width-text)">
        <div style="margin-bottom:0.75rem">
          <a href={`/writing/category/${catSlug}`} class="ds-link">
            <Tag>{category}</Tag>
          </a>
        </div>

        <h1 style="font-family:var(--font-display);font-weight:700;font-size:var(--text-h1);letter-spacing:var(--tracking-display);color:var(--text);line-height:var(--leading-tight);margin-bottom:1rem">
          {title}
        </h1>

        <p style="font-size:var(--text-base);line-height:var(--leading-relaxed);color:var(--text-muted);margin-bottom:1.25rem">{description}</p>

        <div class="flex flex-wrap items-center gap-4" style="font-family:var(--font-mono);font-size:var(--text-xs);color:var(--text-faint)">
          <span>{published}</span>
          {updated && updated !== published && <span>· Updated {updated}</span>}
          <span>· {readTimeStr}</span>
        </div>
      </header>

      <!-- Article Content -->
      <div class="prose" style="max-width:var(--max-width-text);margin:0 auto 0 0">
        <slot />
      </div>

      <!-- Footer tags -->
      <footer style="margin-top:3rem;padding-top:2rem;border-top:1px solid var(--border);max-width:var(--max-width-text)">
        <div class="flex flex-wrap gap-2">
          {tags.map((tag) => <Tag>{tag}</Tag>)}
        </div>
        <div style="margin-top:1.5rem">
          <a href="/writing" class="ds-link" style="font-family:var(--font-mono);font-size:var(--text-xs);color:var(--text-muted)">← Back to Writing</a>
        </div>
      </footer>
    </div>
  </article>
</BaseLayout>
