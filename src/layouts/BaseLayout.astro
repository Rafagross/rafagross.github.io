---
import '../styles/global.css';
import Nav from '../components/islands/Nav.jsx';
import Footer from '../components/islands/Footer.jsx';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
  noIndex?: boolean;
}

const {
  title,
  description = 'Elvis Rafael Gross — CloudOps Engineer, Platform Engineer, SRE. AWS, Kubernetes, observability, and operational excellence.',
  ogImage = '/og-default.png',
  canonicalUrl,
  noIndex = false,
} = Astro.props;

const siteUrl = 'https://rafagross.github.io';
const canonical = canonicalUrl ?? new URL(Astro.url.pathname, siteUrl).href;
const fullTitle = title === 'Home'
  ? 'Elvis Rafael Gross — CloudOps & Platform Engineer'
  : `${title} | Rafael Gross`;
---

<!doctype html>
<html lang="en" class="no-transition">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />
    <meta property="og:site_name" content="Rafael Gross — CloudOps Portfolio" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- RSS Feed -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Rafael Gross — Writing & Runbooks"
      href="/rss.xml"
    />

    <!-- Fonts: Space Grotesk (display/sans) + JetBrains Mono (technical) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Theme + language initialization — runs before paint to prevent FOUC.
         Default theme is dark. Runs on every (full) page load. -->
    <script is:inline>
      (function () {
        const t = localStorage.getItem('theme') ?? 'dark';
        document.documentElement.classList.toggle('dark', t === 'dark');
        document.documentElement.setAttribute('data-theme', t);
        const l = localStorage.getItem('lang') ?? 'en';
        document.documentElement.setAttribute('data-lang', l);
      })();
    </script>
  </head>
  <body>
    <!-- Remove no-transition class after hydration to enable smooth transitions -->
    <script is:inline>
      document.documentElement.classList.remove('no-transition');
    </script>

    <!-- Custom cursor elements (hidden on touch, animated by ds-interactions.ts) -->
    <div id="ds-cursor" aria-hidden="true"></div>
    <div id="ds-cursor-ring" aria-hidden="true"></div>

    <Nav client:load />
    <main id="main-content">
      <slot />
    </main>
    <Footer client:visible />
    <script>
      import '../scripts/ds-interactions.ts';
    </script>
  </body>
</html>
