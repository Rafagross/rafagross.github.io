---
import BaseLayout from './BaseLayout.astro';
import Tag from '../components/ds/Tag.astro';
import Badge from '../components/ds/Badge.astro';
import { formatDate } from '../lib/filters';

interface TechStack {
  [key: string]: string[];
}

interface Props {
  title: string;
  shortDescription: string;
  longDescription: string;
  category: string;
  status: string;
  tags: string[];
  techStack: TechStack;
  awsServices: string[];
  gcpServices: string[];
  architecture: {
    summary: string;
    diagramUrl?: string;
    diagramAlt?: string;
  };
  screenshots?: { src: string; alt?: string; caption?: string }[];
  operationalValue: {
    problemSolved: string;
    outcomes: string[];
    metrics?: {
      costImpact?: string;
      reliabilityImpact?: string;
    };
  };
  links: {
    readme?: string | null;
    runbook?: string | null;
    diagram?: string | null;
    demo?: string | null;
    github?: string;
  };
  publishedDate: string;
  updatedDate?: string;
}

const {
  title,
  shortDescription,
  longDescription,
  category,
  status,
  tags,
  techStack,
  awsServices,
  gcpServices,
  architecture,
  screenshots,
  operationalValue,
  links,
  publishedDate,
  updatedDate,
} = Astro.props;

const published = formatDate(new Date(publishedDate));
const updated = updatedDate ? formatDate(new Date(updatedDate)) : null;
const allCloudServices = [...awsServices, ...gcpServices];
---

<BaseLayout title={title} description={shortDescription}>
  <article style="padding:3rem 0 4rem">
    <div style="width:100%;max-width:var(--max-width);margin-left:auto;margin-right:auto;padding-left:1.5rem;padding-right:1.5rem">
      <!-- Breadcrumb -->
      <nav class="mb-8" aria-label="Breadcrumb">
        <ol class="flex items-center gap-2" style="font-family:var(--font-mono);font-size:var(--text-xs);color:var(--text-faint)">
          <li><a href="/projects" class="ds-link" style="color:var(--text-muted)">Projects</a></li>
          <li aria-hidden="true">/</li>
          <li aria-current="page" style="color:var(--text-faint)">{title}</li>
        </ol>
      </nav>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <!-- Main content -->
        <div class="lg:col-span-2">
          <!-- Header -->
          <header class="mb-10">
            <div class="flex flex-wrap items-center gap-3 mb-4">
              <Badge variant="muted">{status}</Badge>
              <span style="font-family:var(--font-mono);font-size:var(--text-xs);color:var(--text-faint)">{category}</span>
            </div>
            <h1 style="font-family:var(--font-display);font-weight:700;font-size:var(--text-h1);letter-spacing:var(--tracking-display);color:var(--text);line-height:var(--leading-tight);margin-bottom:1rem">
              {title}
            </h1>
            <p style="font-size:var(--text-lg);line-height:var(--leading-relaxed);color:var(--text-muted);margin-bottom:1.5rem">
              {longDescription}
            </p>
            <div class="flex flex-wrap gap-2">
              {tags.map((tag) => <Tag>{tag}</Tag>)}
            </div>
          </header>

          <!-- Architecture -->
          <section class="mb-10">
            <h2 style="font-family:var(--font-display);font-weight:700;font-size:var(--text-h2);letter-spacing:var(--tracking-tight);color:var(--text);margin-bottom:1rem;padding-bottom:0.5rem;border-bottom:1px solid var(--border)">
              Architecture
            </h2>
            <p style="margin-bottom:1.5rem;line-height:var(--leading-relaxed);color:var(--text-muted)">{architecture.summary}</p>

            {architecture.diagramUrl && (
              <div style="border:1px solid var(--border);border-radius:var(--radius);background:var(--surface);overflow:hidden">
                <!-- Diagram toolbar -->
                <div style="display:flex;align-items:center;justify-content:space-between;padding:0.5rem 1rem;border-bottom:1px solid var(--border);background:var(--bg-subtle)">
                  <span style="font-family:var(--font-mono);font-size:var(--text-xs);color:var(--text-faint)">Architecture Diagram</span>
                  <a
                    href={architecture.diagramUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="ds-link"
                    style="font-family:var(--font-mono);font-size:var(--text-xs);color:var(--text-muted)"
                  >
                    Open full size ↗
                  </a>
                </div>
                <!-- SVG diagram -->
                <div style="padding:1rem;overflow-x:auto">
                  <img
                    src={architecture.diagramUrl}
                    alt={architecture.diagramAlt ?? `${title} architecture diagram`}
                    class="w-full h-auto rounded"
                    style="max-width:100%; display:block;"
                    loading="lazy"
                  />
                </div>
              </div>
            )}
          </section>

          <!-- Screenshots -->
          {screenshots && screenshots.length > 0 && (
            <section class="mb-10">
              <h2 style="font-family:var(--font-display);font-weight:700;font-size:var(--text-h2);letter-spacing:var(--tracking-tight);color:var(--text);margin-bottom:1rem;padding-bottom:0.5rem;border-bottom:1px solid var(--border)">
                Screenshots
              </h2>
              <p style="margin-bottom:1.5rem;line-height:var(--leading-relaxed);color:var(--text-muted)">
                Live console captures from the running platform.
              </p>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                {screenshots.map((shot) => (
                  <figure style="margin:0;border:1px solid var(--border);border-radius:var(--radius);background:var(--surface);overflow:hidden">
                    <a href={shot.src} target="_blank" rel="noopener noreferrer" style="display:block" aria-label={shot.caption ?? shot.alt ?? `${title} screenshot`}>
                      <img
                        src={shot.src}
                        alt={shot.alt ?? shot.caption ?? `${title} screenshot`}
                        loading="lazy"
                        style="width:100%;height:auto;display:block;border-bottom:1px solid var(--border)"
                      />
                    </a>
                    {shot.caption && (
                      <figcaption style="padding:0.625rem 0.875rem;font-family:var(--font-mono);font-size:var(--text-xs);color:var(--text-muted);line-height:var(--leading-normal)">
                        {shot.caption}
                      </figcaption>
                    )}
                  </figure>
                ))}
              </div>
            </section>
          )}

          <!-- Operational Value -->
          <section class="mb-10">
            <h2 style="font-family:var(--font-display);font-weight:700;font-size:var(--text-h2);letter-spacing:var(--tracking-tight);color:var(--text);margin-bottom:1rem;padding-bottom:0.5rem;border-bottom:1px solid var(--border)">
              Operational Value
            </h2>
            <div style="margin-bottom:1rem;padding:1rem;border-radius:var(--radius-sm);background:var(--bg-subtle);border-left:3px solid var(--border-strong)">
              <p style="font-family:var(--font-display);font-weight:600;font-size:var(--text-sm);color:var(--text);margin-bottom:0.25rem">Problem Solved</p>
              <p style="color:var(--text-muted);line-height:var(--leading-relaxed)">{operationalValue.problemSolved}</p>
            </div>
            <ul style="list-style:none;padding:0;margin:0 0 1.5rem">
              {operationalValue.outcomes.map((outcome) => (
                <li style="display:flex;align-items:flex-start;gap:0.75rem;margin-bottom:0.5rem">
                  <span style="font-family:var(--font-mono);font-size:var(--text-xs);color:var(--text-faint);margin-top:0.2rem;flex-shrink:0">✓</span>
                  <span style="color:var(--text-muted);line-height:var(--leading-relaxed)">{outcome}</span>
                </li>
              ))}
            </ul>
            {operationalValue.metrics && (
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                {operationalValue.metrics.costImpact && (
                  <div style="padding:1rem;border-radius:var(--radius-sm);background:var(--surface);border:1px solid var(--border)">
                    <p style="font-family:var(--font-mono);font-size:var(--text-xs);text-transform:uppercase;letter-spacing:0.1em;color:var(--text-faint);margin-bottom:0.25rem">Cost Impact</p>
                    <p style="font-size:var(--text-sm);color:var(--text)">{operationalValue.metrics.costImpact}</p>
                  </div>
                )}
                {operationalValue.metrics.reliabilityImpact && (
                  <div style="padding:1rem;border-radius:var(--radius-sm);background:var(--surface);border:1px solid var(--border)">
                    <p style="font-family:var(--font-mono);font-size:var(--text-xs);text-transform:uppercase;letter-spacing:0.1em;color:var(--text-faint);margin-bottom:0.25rem">Reliability Impact</p>
                    <p style="font-size:var(--text-sm);color:var(--text)">{operationalValue.metrics.reliabilityImpact}</p>
                  </div>
                )}
              </div>
            )}
          </section>

          <!-- MDX Content slot -->
          <section class="prose" style="max-width:var(--max-width-text)">
            <slot />
          </section>
        </div>

        <!-- Sidebar -->
        <aside class="lg:col-span-1">
          <div class="sticky top-24 space-y-6">
            <!-- Links -->
            <div style="padding:1.25rem;border-radius:var(--radius);background:var(--surface);border:1px solid var(--border)">
              <h3 style="font-family:var(--font-mono);font-size:var(--text-xs);font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:var(--text-faint);margin-bottom:1rem">Links</h3>
              <div class="space-y-2">
                {links.github && (
                  <a href={links.github} target="_blank" rel="noopener noreferrer"
                    style="display:flex;align-items:center;gap:0.5rem;font-size:var(--text-sm);padding:0.5rem 0.75rem;border-radius:var(--radius-sm);background:var(--bg-subtle);color:var(--text);border:1px solid var(--border);text-decoration:none;transition:border-color 0.12s"
                    onmouseover="this.style.borderColor='var(--border-strong)'" onmouseout="this.style.borderColor='var(--border)'">
                    ↗ GitHub Repository
                  </a>
                )}
                {links.runbook && (
                  <a href={links.runbook}
                    style="display:flex;align-items:center;gap:0.5rem;font-size:var(--text-sm);padding:0.5rem 0.75rem;border-radius:var(--radius-sm);background:var(--bg-subtle);color:var(--text);border:1px solid var(--border);text-decoration:none;transition:border-color 0.12s"
                    onmouseover="this.style.borderColor='var(--border-strong)'" onmouseout="this.style.borderColor='var(--border)'">
                    → Runbook
                  </a>
                )}
                {links.readme && (
                  <a href={links.readme} target="_blank" rel="noopener noreferrer"
                    style="display:flex;align-items:center;gap:0.5rem;font-size:var(--text-sm);padding:0.5rem 0.75rem;border-radius:var(--radius-sm);background:var(--bg-subtle);color:var(--text);border:1px solid var(--border);text-decoration:none;transition:border-color 0.12s"
                    onmouseover="this.style.borderColor='var(--border-strong)'" onmouseout="this.style.borderColor='var(--border)'">
                    → README
                  </a>
                )}
                {architecture.diagramUrl && (
                  <a href={architecture.diagramUrl} target="_blank" rel="noopener noreferrer"
                    style="display:flex;align-items:center;gap:0.5rem;font-size:var(--text-sm);padding:0.5rem 0.75rem;border-radius:var(--radius-sm);background:var(--bg-subtle);color:var(--text);border:1px solid var(--border);text-decoration:none;transition:border-color 0.12s"
                    onmouseover="this.style.borderColor='var(--border-strong)'" onmouseout="this.style.borderColor='var(--border)'">
                    → Architecture Diagram
                  </a>
                )}
              </div>
            </div>

            <!-- Tech Stack -->
            <div style="padding:1.25rem;border-radius:var(--radius);background:var(--surface);border:1px solid var(--border)">
              <h3 style="font-family:var(--font-mono);font-size:var(--text-xs);font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:var(--text-faint);margin-bottom:1rem">Tech Stack</h3>
              <div class="space-y-3">
                {Object.entries(techStack).map(([group, items]) => (
                  <div>
                    <p style="font-family:var(--font-mono);font-size:var(--text-xs);color:var(--text-faint);margin-bottom:0.375rem;text-transform:capitalize">{group.replace(/([A-Z])/g, ' $1').trim()}</p>
                    <div class="flex flex-wrap gap-1.5">
                      {(items as string[]).map((item) => <Tag>{item}</Tag>)}
                    </div>
                  </div>
                ))}
              </div>
            </div>

            <!-- Cloud Services -->
            {allCloudServices.length > 0 && (
              <div style="padding:1.25rem;border-radius:var(--radius);background:var(--surface);border:1px solid var(--border)">
                <h3 style="font-family:var(--font-mono);font-size:var(--text-xs);font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:var(--text-faint);margin-bottom:0.75rem">Cloud Services</h3>
                <div class="flex flex-wrap gap-1.5">
                  {allCloudServices.map((svc) => <Tag>{svc}</Tag>)}
                </div>
              </div>
            )}

            <!-- Metadata -->
            <div style="font-family:var(--font-mono);font-size:var(--text-xs);color:var(--text-faint);line-height:var(--leading-normal)">
              <p>Published: {published}</p>
              {updated && <p style="margin-top:0.25rem">Updated: {updated}</p>}
            </div>
          </div>
        </aside>
      </div>
    </div>
  </article>
</BaseLayout>
