---
import BaseLayout from './BaseLayout.astro';
import Tag from '../components/ds/Tag.astro';
import Badge from '../components/ds/Badge.astro';
import { formatDate } from '../lib/filters';

interface Props {
  title: string;
  description: string;
  category: string;
  tags: string[];
  severity: string;
  estimatedTime: string;
  status: string;
  publishedDate: Date;
  updatedDate?: Date;
  awsServices: string[];
  prerequisites: string[];
  relatedRunbooks: string[];
}

const {
  title,
  description,
  category,
  tags,
  severity,
  estimatedTime,
  status,
  publishedDate,
  updatedDate,
  awsServices,
  prerequisites,
  relatedRunbooks,
} = Astro.props;

const published = formatDate(publishedDate);
const updated = updatedDate ? formatDate(updatedDate) : null;
---

<BaseLayout title={title} description={description}>
  <article style="padding:3rem 0 4rem">
    <div style="width:100%;max-width:var(--max-width);margin-left:auto;margin-right:auto;padding-left:1.5rem;padding-right:1.5rem">
      <!-- Breadcrumb -->
      <nav class="mb-8" aria-label="Breadcrumb">
        <ol class="flex items-center gap-2" style="font-family:var(--font-mono);font-size:var(--text-xs);color:var(--text-faint)">
          <li><a href="/runbooks" class="ds-link" style="color:var(--text-muted)">Runbooks</a></li>
          <li aria-hidden="true">/</li>
          <li aria-current="page" style="color:var(--text-faint)">{title}</li>
        </ol>
      </nav>

      <div class="grid grid-cols-1 lg:grid-cols-4 gap-12">
        <!-- Main content -->
        <div class="lg:col-span-3">
          <!-- Header -->
          <header class="mb-10 pb-8" style="border-bottom:1px solid var(--border)">
            <div class="flex flex-wrap items-center gap-3 mb-4">
              <Badge variant="muted">{severity}</Badge>
              <Badge variant="muted">{status}</Badge>
              <span style="font-family:var(--font-mono);font-size:var(--text-xs);color:var(--text-faint)">{category}</span>
            </div>

            <h1 style="font-family:var(--font-display);font-weight:700;font-size:var(--text-h1);letter-spacing:var(--tracking-display);color:var(--text);line-height:var(--leading-tight);margin-bottom:1rem">
              {title}
            </h1>

            <p style="font-size:var(--text-base);line-height:var(--leading-relaxed);color:var(--text-muted);margin-bottom:1.25rem">{description}</p>

            <!-- Quick info bar -->
            <div class="flex flex-wrap gap-6" style="font-family:var(--font-mono);font-size:var(--text-xs);color:var(--text-faint)">
              <div class="flex items-center gap-1.5">
                <span>~</span>
                <span>{estimatedTime}</span>
              </div>
              <div class="flex items-center gap-1.5">
                <span>Updated {updated ?? published}</span>
              </div>
              {awsServices.length > 0 && (
                <div class="flex items-center gap-1.5">
                  <span>{awsServices.slice(0, 3).join(', ')}{awsServices.length > 3 ? ` +${awsServices.length - 3}` : ''}</span>
                </div>
              )}
            </div>
          </header>

          <!-- Prerequisites callout -->
          {prerequisites.length > 0 && (
            <div style="margin-bottom:2rem;padding:1.25rem;border-radius:var(--radius);background:var(--surface);border:1px solid var(--border);border-left:3px solid var(--border-strong)">
              <p style="font-family:var(--font-display);font-size:var(--text-sm);font-weight:600;color:var(--text);margin-bottom:0.75rem">Prerequisites</p>
              <ul style="list-style:none;padding:0;margin:0">
                {prerequisites.map((req) => (
                  <li style="display:flex;align-items:flex-start;gap:0.5rem;font-size:var(--text-sm);color:var(--text-muted);margin-bottom:0.375rem">
                    <span style="font-family:var(--font-mono);margin-top:0.1rem;flex-shrink:0">→</span>
                    <span>{req}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}

          <!-- MDX Content -->
          <div class="prose" style="max-width:var(--max-width-text)">
            <slot />
          </div>
        </div>

        <!-- Sidebar -->
        <aside class="lg:col-span-1">
          <div class="sticky top-24 space-y-6">
            <!-- Quick Reference -->
            <div style="padding:1.25rem;border-radius:var(--radius);background:var(--surface);border:1px solid var(--border)">
              <h3 style="font-family:var(--font-mono);font-size:var(--text-xs);font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:var(--text-faint);margin-bottom:1rem">Quick Reference</h3>
              <div class="space-y-3">
                <div>
                  <p style="font-family:var(--font-mono);font-size:var(--text-xs);color:var(--text-faint);margin-bottom:0.25rem">Severity</p>
                  <Badge variant="muted">{severity}</Badge>
                </div>
                <div>
                  <p style="font-family:var(--font-mono);font-size:var(--text-xs);color:var(--text-faint);margin-bottom:0.25rem">Est. Time</p>
                  <p style="font-family:var(--font-mono);font-size:var(--text-sm);color:var(--text)">{estimatedTime}</p>
                </div>
                <div>
                  <p style="font-family:var(--font-mono);font-size:var(--text-xs);color:var(--text-faint);margin-bottom:0.25rem">Status</p>
                  <Badge variant="muted">{status}</Badge>
                </div>
              </div>
            </div>

            <!-- AWS Services -->
            {awsServices.length > 0 && (
              <div style="padding:1.25rem;border-radius:var(--radius);background:var(--surface);border:1px solid var(--border)">
                <h3 style="font-family:var(--font-mono);font-size:var(--text-xs);font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:var(--text-faint);margin-bottom:0.75rem">AWS Services</h3>
                <div class="flex flex-wrap gap-1.5">
                  {awsServices.map((svc) => <Tag>{svc}</Tag>)}
                </div>
              </div>
            )}

            <!-- Tags -->
            {tags.length > 0 && (
              <div style="padding:1.25rem;border-radius:var(--radius);background:var(--surface);border:1px solid var(--border)">
                <h3 style="font-family:var(--font-mono);font-size:var(--text-xs);font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:var(--text-faint);margin-bottom:0.75rem">Tags</h3>
                <div class="flex flex-wrap gap-1.5">
                  {tags.map((tag) => <Tag>{tag}</Tag>)}
                </div>
              </div>
            )}

            <!-- Related Runbooks -->
            {relatedRunbooks.length > 0 && (
              <div style="padding:1.25rem;border-radius:var(--radius);background:var(--surface);border:1px solid var(--border)">
                <h3 style="font-family:var(--font-mono);font-size:var(--text-xs);font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:var(--text-faint);margin-bottom:0.75rem">Related Runbooks</h3>
                <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.5rem">
                  {relatedRunbooks.map((slug) => (
                    <li>
                      <a href={`/runbooks/${slug}`} class="ds-link" style="font-family:var(--font-mono);font-size:var(--text-xs);color:var(--text-muted)">
                        → {slug.replace(/-/g, ' ')}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            )}

            <!-- Dates -->
            <div style="font-family:var(--font-mono);font-size:var(--text-xs);color:var(--text-faint);line-height:var(--leading-normal)">
              <p>Published: {published}</p>
              {updated && <p style="margin-top:0.25rem">Updated: {updated}</p>}
            </div>
          </div>
        </aside>
      </div>
    </div>
  </article>
</BaseLayout>
